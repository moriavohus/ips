NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SITE_URL=https://ipsme.ae

# Admin Panel (CHANGE THESE IN PRODUCTION!)
ADMIN_USERNAME=ips_admin
ADMIN_PASSWORD=CHANGE_ME_strong_password_here
SESSION_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# Admin content sync for Netlify production
# Create a GitHub fine-grained token with Contents: Read and write for this repository.
GITHUB_TOKEN=
GITHUB_REPO=owner/repository
GITHUB_BRANCH=main

# Optional: Netlify build hook URL. GitHub commits usually trigger Netlify automatically.
NETLIFY_BUILD_HOOK_URL=
